# Server Configuration
PORT=8002
ENV=development

# Database Configuration
# Supported dialects: sqlite, postgres, mysql
DB_DIALECT=sqlite
DB_NAME=police_fir.db
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me
DB_SSLMODE=require

# JWT Authentication Configuration
JWT_SECRET=replace_with_at_least_32_random_characters
JWT_EXPIRY_HOURS=8

# Authentication: use local only for development; use oidc with Keycloak in production.
AUTH_MODE=local
OIDC_ISSUER=http://127.0.0.1:8081/realms/police-intelligence
OIDC_AUDIENCE=crime-api
OIDC_JWKS_URL=http://127.0.0.1:8081/realms/police-intelligence/protocol/openid-connect/certs
# Leave empty until the OPA container is running.
OPA_URL=

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# External AI orchestration (provision before enabling model inference)
AI_ENABLED=false
AI_PROVIDER=gemini
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
AI_MODEL=gemini-3.5-flash
AI_API_KEY=replace_with_rotated_gemini_key

# Required governed AI services
TRANSLATION_BASE_URL=https://api.sarvam.ai
SARVAM_API_KEY=replace_with_rotated_sarvam_key
EMBEDDING_BASE_URL=http://127.0.0.1:8020
SEARCH_BASE_URL=http://127.0.0.1:9200
SEARCH_INDEX=police-cases
SEARCH_USERNAME=
SEARCH_PASSWORD=
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_BUCKET=police-evidence
OBJECT_STORAGE_REGION=us-east-1
GRAPH_BASE_URL=http://127.0.0.1:7474
GRAPH_USERNAME=neo4j
GRAPH_PASSWORD=
